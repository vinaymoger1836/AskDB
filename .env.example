# Copy this file to .env and fill in real values. NEVER commit .env.
# Groq — LLM (Llama 3.3 70B) that writes the SQL. Get a key at https://console.groq.com
GROQ_API_KEY=

# ---- Optional tunables (sensible defaults applied in app/config.py) ----
# Groq chat model.
GROQ_MODEL=llama-3.3-70b-versatile
# Path to the seeded SQLite database.
DB_PATH=data/sales.db
# Hard cap on rows returned by any query (LIMIT is injected/clamped to this).
MAX_LIMIT=100
# Max self-correction retries when the LLM's SQL fails to validate/run.
AGENT_MAX_RETRIES=2
# Per-query statement timeout (seconds).
QUERY_TIMEOUT_S=5
# Base URL the Streamlit UI uses to reach the FastAPI backend.
ASKDB_API_BASE=http://localhost:8000
